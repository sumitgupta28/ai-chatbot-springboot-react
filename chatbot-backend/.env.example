# LLM provider: "ollama" (default) or "anthropic"
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2

# Anthropic settings (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# Database — asyncpg for SQLAlchemy async ORM
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ragdb

# Database — psycopg2 for LangChain PGVector and Alembic (sync)
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ragdb

# RAG defaults (used when no per-request overrides are supplied)
RAG_MODE=soft
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.0

# Embedding model (local, always used regardless of LLM provider)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Max upload file size in MB
MAX_UPLOAD_SIZE_MB=50
