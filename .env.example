# For Anthropic profile only (SPRING_PROFILES_ACTIVE=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override Ollama base URL when running via Docker Compose
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Set to 'anthropic' to use the Anthropic profile; leave unset for Ollama (default)
# SPRING_PROFILES_ACTIVE=anthropic
